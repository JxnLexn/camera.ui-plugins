{
  "displayName": "TP-Link Tapo",
  "name": "@camera.ui/camera-ui-tapo",
  "version": "0.1.0",
  "description": "Lokale TP-Link-Tapo-Integration mit ONVIF/RTSP, Ereignissensoren, Videobewegungserkennung und H200-Türklingelereignissen.",
  "author": "camera.ui contributors",
  "type": "module",
  "main": "./bundle/dist/index.js",
  "scripts": {
    "build": "rimraf dist && npm run build:onvif && tsc",
    "build:onvif": "npm --prefix ../externals/onvif ci --ignore-scripts && npm --prefix ../externals/onvif run build",
    "bundle": "npm run format && npm run lint && npm run build && cui bundle",
    "bundle:dev": "npm run format && npm run lint && npm run build && cross-env MODE=development cui bundle",
    "format": "prettier --write \"src/\" --ignore-unknown --no-error-on-unmatched-pattern",
    "lint": "eslint --fix .",
    "test": "vitest run"
  },
  "dependencies": {
    "@seydx/onvif": "file:../externals/onvif"
  },
  "devDependencies": {
    "@camera.ui/cli": "^0.0.65",
    "@camera.ui/sdk": "^0.0.22",
    "@eslint/js": "9.39.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "26.1.1",
    "@typescript-eslint/parser": "^8.64.0",
    "cross-env": "^10.1.0",
    "eslint": "9.39.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "camera.ui": ">=2.0.12",
    "node": ">=22.0.0"
  },
  "os": [],
  "cpu": [],
  "keywords": [
    "camera-ui-plugin",
    "tapo",
    "tp-link",
    "onvif",
    "rtsp",
    "doorbell",
    "h200"
  ],
  "license": "MIT"
}
